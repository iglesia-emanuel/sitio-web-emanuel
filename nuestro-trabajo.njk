---
<div class="page-hero">
  <div class="container">
    <span class="eyebrow">{{ hero.eyebrow }}</span>
    <h1>{{ hero.title }}</h1>
    <p>{{ hero.body }}</p>
  </div>
</div>

<section>
  <div class="container">
    {% for p in programs %}
    <div class="program-block{% if p.reverse %} reverse{% endif %}" id="{{ p.id }}">
      <div class="program-media"><img src="{{ p.image }}" alt="{{ p.image_alt }}"></div>
      <div class="program-body">
        <span class="eyebrow">{{ p.eyebrow }}</span>
        <h3>{{ p.title }}</h3>
        <p>{{ p.body | safe }}</p>
        <div class="results-row">
          {% for r in p.results %}
          <span class="result-chip{% if p.results_placeholder %} placeholder{% endif %}">{{ r }}</span>
          {% endfor %}
        </div>
        {% if p.extra %}<p style="margin-top:14px;font-size:0.85rem;">{{ p.extra | safe }}</p>{% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<section class="bg-cream tight">
  <div class="container quote-block">
    <div class="quote-mark">"</div>
    <blockquote>{{ quote.text }}</blockquote>
    <div class="quote-author">{{ quote.author }}</div>
  </div>
</section>

<section>
  <div class="container">
    <div class="cta-banner">
      <div>
        <h2>{{ cta.title }}</h2>
        <p>{{ cta.body }}</p>
      </div>
      <a href="/sumate/" class="btn btn-primary">Ver formas de colaborar</a>
    </div>
  </div>
</section>
