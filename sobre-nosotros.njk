    icon: "landmark.png"
---
<div class="page-hero">
  <div class="container">
    <span class="eyebrow">{{ hero.eyebrow }}</span>
    <h1>{{ hero.title }}</h1>
    <p>{{ hero.body }}</p>
  </div>
</div>

<section class="tight bg-cream">
  <div class="container">
    <div class="identity-box">
      <h4>{{ identity_box.title }}</h4>
      <p>{{ identity_box.body }}</p>
    </div>
  </div>
</section>

<section>
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Nuestra historia</span>
      <h2>Más de 70 años de trayectoria</h2>
      <p>{{ historia_intro }}</p>
    </div>
    <div class="timeline">
      {% for t in timeline %}
      <div class="timeline-point">
        <div class="timeline-dot"></div>
        <div class="timeline-year">{{ t.year }}</div>
        <div class="timeline-desc">{{ t.text }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="bg-cream tight">
  <div class="container quote-block">
    <div class="quote-mark">"</div>
    <blockquote>{{ quote.text }}</blockquote>
    <div class="quote-author">{{ quote.author }}</div>
  </div>
</section>

<section>
  <div class="container">
    <div class="section-head center mx-auto">
      <span class="eyebrow">Nuestra identidad</span>
      <h2>Los principios que guían cada decisión</h2>
    </div>
    <div class="grid grid-4">
      {% for v in values %}
      <div class="value-card">
        <span class="icon-circle {{ v.color }}"><img src="https://6a5b82756ffa544c41fc3967--zippy-sundae-69844e.netlify.app/icons/{{ v.icon }}" alt=""></span>
        <h3>{{ v.name }}</h3>
        <p>{{ v.body }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="bg-cream">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Gobierno institucional</span>
      <h2>Nuestra estructura</h2>
    </div>
    {% for tier in org_tiers %}
    <div class="org-tier">
      <div class="org-tier-label">{{ tier.label }}</div>
      <div class="org-people">
        {% for person in tier.people %}
        <div class="org-person"><strong{% if person.placeholder %} class="placeholder-text"{% endif %}>{{ person.name }}</strong><span>{{ person.role }}</span></div>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<section id="transparencia">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Transparencia</span>
      <h2>Cómo administramos los recursos</h2>
    </div>
    <div class="two-col-divider">
      <div class="col">
        <h3 style="margin-bottom:20px;">Datos legales</h3>
        {% for row in legal_rows %}
        <div class="legal-row"><span>{{ row.label }}</span><span>{{ row.value }}</span></div>
        {% endfor %}
      </div>
      <div class="col">
        <h3 style="margin-bottom:20px;">Cómo rendimos cuentas</h3>
        {% for item in trust_items %}
        <div class="trust-item">
          <span class="icon-circle teal"><img src="https://6a5b82756ffa544c41fc3967--zippy-sundae-69844e.netlify.app/icons/{{ item.icon }}" alt=""></span>
          <div><h4>{{ item.title }}</h4><p>{{ item.body }}</p></div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<section class="bg-cream">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Capacidad operativa</span>
      <h2>La estructura para sostener este trabajo</h2>
    </div>
    <div class="grid grid-3">
      {% for c in capacidad %}
      <div class="help-tile"><span class="icon-circle dark" style="width:44px;height:44px;margin-bottom:14px;"><img src="https://6a5b82756ffa544c41fc3967--zippy-sundae-69844e.netlify.app/icons/{{ c.icon }}" alt="" style="width:20px;height:20px;"></span><h4>{{ c.title }}</h4><p>{{ c.body }}</p></div>
      {% endfor %}
    </div>
    <div class="text-center" style="margin-top:44px;"><a href="/nuestro-trabajo/" class="btn btn-dark">Ver nuestro trabajo</a></div>
  </div>
</section>
